{
  "modelId": "prunaai/z-image-turbo",
  "provider": "replicate",
  "displayName": "Z Image Turbo",
  "category": "image-generation",
  "pricingSourceUrl": "https://replicate.com/prunaai/z-image-turbo",
  "pricingNotes": "Replicate pricing is tiered by output image resolution (megapixels).",
  "pricing": {
    "usdPerSecond": null,
    "usdPer1kInputTokens": null,
    "usdPer1kOutputTokens": null
  },
  "pricingRules": {
    "basis": "output_image_megapixels",
    "tiers": [
      {
        "maxMegapixels": 0.5,
        "usdPerImage": 0.0025
      },
      {
        "maxMegapixels": 1,
        "usdPerImage": 0.005
      },
      {
        "maxMegapixels": 2,
        "usdPerImage": 0.01
      },
      {
        "maxMegapixels": 3,
        "usdPerImage": 0.015
      },
      {
        "maxMegapixels": 4,
        "usdPerImage": 0.02
      }
    ]
  },
  "inputOptions": {
    "userConfigurable": [
      "num_inference_steps",
      "guidance_scale",
      "seed",
      "go_fast",
      "output_format",
      "output_quality"
    ],
    "pipelineManaged": [
      "prompt",
      "width",
      "height"
    ],
    "fields": {
      "num_inference_steps": {
        "type": "integer",
        "default": 8,
        "minimum": 1,
        "maximum": 50
      },
      "guidance_scale": {
        "type": "number",
        "default": 0,
        "minimum": 0,
        "maximum": 20
      },
      "seed": {
        "type": "integer",
        "nullable": true
      },
      "go_fast": {
        "type": "boolean",
        "default": false
      },
      "output_format": {
        "type": "string",
        "default": "jpg",
        "enum": [
          "jpg",
          "jpeg",
          "png",
          "webp"
        ]
      },
      "output_quality": {
        "type": "integer",
        "default": 80,
        "minimum": 0,
        "maximum": 100
      },
      "prompt": {
        "type": "string",
        "required": true
      },
      "width": {
        "type": "integer",
        "required": true,
        "minimum": 64,
        "maximum": 2048
      },
      "height": {
        "type": "integer",
        "required": true,
        "minimum": 64,
        "maximum": 2048
      }
    }
  }
}

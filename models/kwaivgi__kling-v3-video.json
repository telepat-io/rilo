    },
    "tiers": [
      {
        "mode": "standard",
        "generateAudio": false,
        "usdPerSecond": 0.168
      },
      {
        "mode": "standard",
        "generateAudio": true,
        "usdPerSecond": 0.252
      },
      {
        "mode": "pro",
        "generateAudio": false,
        "usdPerSecond": 0.224
      },
      {
        "mode": "pro",
        "generateAudio": true,
        "usdPerSecond": 0.336
      }
    ]
  },
  "inputOptions": {
    "userConfigurable": [
      "negative_prompt",
      "mode",
      "generate_audio"

    "pipelineManaged": [
      "prompt",
      "start_image",
      "end_image",
      "duration",
      "aspect_ratio"
    ],
    "fields": {
      "negative_prompt": {
        "type": "string",
        "nullable": true
      },
      "mode": {
        "type": "string",
        "default": "pro",
        "enum": [
          "standard",
          "pro"
        ]
      },
      "generate_audio": {
        "type": "boolean",
        "default": false
      },
      "prompt": {
        "type": "string",
        "required": true
      },
      "start_image": {
        "type": "string",
        "required": true
      },
      "end_image": {
        "type": "string",
        "required": true
      },
      "duration": {
        "type": "integer",
        "required": true,
        "default": 5,
        "minimum": 3,
        "maximum": 15
      },
      "aspect_ratio": {
        "type": "string",
        "required": true,
        "enum": [
          "1:1",
          "16:9",
          "9:16"
        ]
      }
